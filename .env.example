# ── Ollama ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_TEXT=mistral
OLLAMA_MODEL_VISION=llava
OLLAMA_MODEL_FAST=llama3

# ── SerpAPI (free tier — 100 searches/month) ──────────────
SERPAPI_KEY=your_serpapi_key_here

# ── YouTube Data API v3 (free tier) ───────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# ── Stable Diffusion WebUI (local) ────────────────────────
SD_API_URL=http://localhost:7860

# ── Pipeline ──────────────────────────────────────────────
PIPELINE_OUTPUT_DIR=./output
EPISODE_PREFIX=EP

# ── Quality Gate thresholds ───────────────────────────────
MIN_SCRIPT_SCORE=6.0
MIN_CHARACTER_SCORE=5.5

# ── Web UI ────────────────────────────────────────────────
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000
